@model InternshipManagement.Models.InternshipRegistration
@{
    ViewData["Title"] = "Chấm điểm Sinh viên";
}

<div class="row">
    <div class="col-md-8 offset-md-2">
        <h2 class="text-center">Chấm điểm & Nhận xét</h2>
        
        <div class="card mt-4">
            <div class="card-header bg-info text-white">
                <h5 class="mb-0">Thông tin Sinh viên</h5>
            </div>
            <div class="card-body">
                <p><strong>Họ tên:</strong> @Model.Student?.HoTen (@Model.MSSV)</p>
                <p><strong>Thực tập tại:</strong> @Model.Enterprise?.TenDN</p>
                <p>
                    <strong>File báo cáo:</strong> 
                    @if (!string.IsNullOrEmpty(Model.FileBaoCao))
                    {
                        <a href="@Model.FileBaoCao" target="_blank">Tải về / Xem</a>
                    }
                    else
                    {
                        <span class="text-danger">Sinh viên chưa nộp báo cáo.</span>
                    }
                </p>
            </div>
        </div>

        <div class="card mt-4 border-primary">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">Form Chấm Điểm</h5>
            </div>
            <div class="card-body">
                <form asp-action="Grade" method="post">
                    <input type="hidden" name="id" value="@Model.Id" />
                    
                    <div class="form-group mb-3">
                        <label class="fw-bold">Điểm số (Hệ 10):</label>
                        <input type="number" step="0.5" min="0" max="10" name="score" class="form-control" value="@Model.Diem" required />
                    </div>
                    
                    <div class="form-group mb-3">
                        <label class="fw-bold">Nhận xét của Giảng viên:</label>
                        <textarea name="comment" class="form-control" rows="4">@Model.NhanXetGV</textarea>
                    </div>

                    <div class="d-flex justify-content-between mt-3">
                        <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
                        <button type="submit" class="btn btn-success">Lưu Đánh Giá</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
