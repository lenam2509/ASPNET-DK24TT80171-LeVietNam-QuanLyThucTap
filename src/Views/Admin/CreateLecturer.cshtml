@model InternshipManagement.Models.Lecturer
@{
    ViewData["Title"] = "Thêm Giảng viên";
}

<div class="row">
    <div class="col-md-6 offset-md-3">
        <h2 class="text-center">Thêm Giảng viên (Dành cho Admin)</h2>
        @if (TempData["Message"] != null)
        {
            <div class="alert alert-success">@TempData["Message"]</div>
        }
        <form asp-action="CreateLecturer" method="post">
            <div class="form-group mb-3">
                <label asp-for="MaGV"></label>
                <input asp-for="MaGV" class="form-control" required />
                <span asp-validation-for="MaGV" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="HoTen"></label>
                <input asp-for="HoTen" class="form-control" required />
            </div>
            <div class="form-group mb-3">
                <label asp-for="Khoa"></label>
                <input asp-for="Khoa" class="form-control" />
            </div>
            <div class="form-group mb-3">
                <label asp-for="Password"></label>
                <input asp-for="Password" type="password" class="form-control" required />
            </div>
            <button type="submit" class="btn btn-primary w-100">Tạo tài khoản</button>
        </form>
    </div>
</div>
