@model IEnumerable<InternshipManagement.Models.Lecturer>
@{
    ViewData["Title"] = "Quản lý Giảng viên";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Quản lý Giảng viên</h2>
    <a asp-action="CreateLecturer" class="btn btn-primary">Thêm Giảng viên mới</a>
</div>

@if (TempData["Message"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Message"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<form method="get" asp-action="Lecturers" class="mb-4">
    <div class="input-group">
        <input type="text" name="searchString" value="@ViewBag.SearchString" class="form-control" placeholder="Tìm kiếm theo Mã GV, Tên, Khoa..." />
        <button type="submit" class="btn btn-outline-secondary">Tìm kiếm</button>
        @if (!string.IsNullOrEmpty(ViewBag.SearchString))
        {
            <a asp-action="Lecturers" class="btn btn-outline-danger">Xóa lọc</a>
        }
    </div>
</form>

<table class="table table-bordered table-striped">
    <thead class="table-dark">
        <tr>
            <th>Mã GV</th>
            <th>Họ tên</th>
            <th>Khoa/Bộ môn</th>
            <th width="150">Hành động</th>
        </tr>
    </thead>
    <tbody>
        @if (!Model.Any())
        {
            <tr>
                <td colspan="4" class="text-center">Không tìm thấy giảng viên nào.</td>
            </tr>
        }
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.MaGV</td>
                <td>@item.HoTen</td>
                <td>@item.Khoa</td>
                <td>
                    <div class="d-flex gap-2">
                        <a asp-action="EditLecturer" asp-route-id="@item.MaGV" class="btn btn-sm btn-info text-white">Sửa</a>
                        <form asp-action="DeleteLecturer" asp-route-id="@item.MaGV" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn xóa giảng viên này? Toàn bộ dữ liệu liên quan có thể bị ảnh hưởng.');">
                            <button type="submit" class="btn btn-sm btn-danger">Xóa</button>
                        </form>
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>

@if (ViewBag.TotalPages > 1)
{
    <nav aria-label="Page navigation">
        <ul class="pagination justify-content-center">
            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.PageNumber ? "active" : "")">
                    <a class="page-link" asp-action="Lecturers" asp-route-pageNumber="@i" asp-route-searchString="@ViewBag.SearchString">@i</a>
                </li>
            }
        </ul>
    </nav>
}
